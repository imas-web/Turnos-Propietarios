PORT=4000

# Autenticacion
JWT_SECRET=cambiar-este-secreto-en-produccion
ADMIN_USER=admin
ADMIN_PASSWORD=admin123

# Base de datos (ruta del archivo SQLite)
DB_PATH=./data/turnos.db

# URL publica del frontend, usada para armar el link de confirmacion
FRONTEND_URL=http://localhost:5173

# Envio de correo (opcional). Si no se completa, el link de confirmacion
# se muestra en el panel de administracion y en la consola del servidor.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Turnos Propietarios <no-responder@turnos.local>
