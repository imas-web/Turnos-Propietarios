PORT=4000

# Autenticacion
JWT_SECRET=cambiar-este-secreto-en-produccion

# Usuarios iniciales (se crean solos la primera vez que arranca el server).
JIMENA_USER=jimena
JIMENA_PASSWORD=jimena
DANIELA_USER=daniela
DANIELA_PASSWORD=daniela
DIAGNOTEST_USER=diagnotest
DIAGNOTEST_PASSWORD=diagnotest
ADMIN_USER=admin
ADMIN_PASSWORD=admin

# Base de datos Postgres. En Vercel se completa sola al crear el
# almacenamiento Postgres desde el dashboard (Storage -> Create Database).
# En local, apunta a un Postgres propio, por ejemplo:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/turnos_dev

# Envio de correo de confirmacion (opcional). Si se deja vacio, el correo
# no se envia y solo queda un aviso en el log del servidor.
# Para Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=465, SMTP_USER=tu cuenta
# de Gmail completa, SMTP_PASS=una "contrasena de aplicacion" generada en
# https://myaccount.google.com/apppasswords (no la contrasena normal).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Diagnotest <tu-cuenta@gmail.com>
